# ── Chatwoot (Application API) ──
CHATWOOT_BASE_URL=https://chat.engosoft.com
CHATWOOT_ACCOUNT_ID=2
CHATWOOT_API_TOKEN=put_rotated_token_here   # ⚠ rotate any token that was ever pasted in chat/repos

# API Channel inbox — identifier (preferred) or numeric id (either works).
CHATWOOT_INBOX_IDENTIFIER=your_inbox_identifier
CHATWOOT_INBOX_ID=29

# ── Botpress Chat API (the REAL messaging path) ──
# Install the "Chat" integration on the bot (Botpress Studio → Integrations → Chat).
# Its config page shows: Webhook URL = https://chat.botpress.cloud/<id>  → put <id> here.
# NOTE: this is NOT the "Webhook" integration (webhook.botpress.cloud) — that one is wrong.
BOTPRESS_CHAT_WEBHOOK_ID=your_chat_integration_webhook_id
# BOTPRESS_CHAT_API_BASE=https://chat.botpress.cloud   # default, override only for testing

# ── Widget ──
# Exact origin of the Odoo site that hosts the «نور» widget (CORS).
WIDGET_ORIGIN=https://demo.engosoft.com

# Max customer attachment size in MB (POST /widget/upload). Default 10.
# MAX_UPLOAD_MB=10

PORT=3000

# ── «نور» welcome (sent once when the chat opens) ──
WELCOME_ENABLED=true
WELCOME_CARD_ENABLED=false
WELCOME_TEXT=أهلاً 👋 أنا ماجد، مستشارك التعليمي في Engosoft. اسألني عن أي دورة أو عن تقدّمك في التعلّم.
# Choice buttons under the welcome (| separated). Empty WELCOME_CHOICES disables them.
WELCOME_CHOICES_TEXT=اختر ما يناسبك:
WELCOME_CHOICES=أبحث عن كورس مناسب لي|أسعار الدورات|مجالات التدريب المتاحة|تواصل مع فريق المبيعات
WELCOME_CARD_TITLE=تواصل مع Engosoft
# WhatsApp number + support email. Used by the welcome card AND the widget's
# contact buttons (واتساب / إيميل). Set here to control them without editing Odoo.
WA_NUMBER=966920016295
SUPPORT_EMAIL=aibot@engosoft.com

# ── «نور» teaser / popup (the bubble above the chat launcher) ──
# Control the teaser text, promo code, and where the course-page teaser appears —
# all from here, no code or Odoo changes. Change a value → Redeploy on Railway.
#
# Discount / promo code shown on the bubble:
# MAJED_PROMO_CODE=free100
#
# Discount code for logged-in customers (20% off any course) — its own teaser,
# shown only after login (alongside the welcome teaser):
# MAJED_DISCOUNT_CODE=engo20
#
# Course-page teaser (shown only on course/product pages). {{course}} = the course
# name read live from the page, so the bot knows which course the customer is on.
# MAJED_COURSE_TEASER_HTML=🛒 محتاج مساعدة في شراء «{{course}}»؟<br/>أو في عرض حاليًا؟
# MAJED_COURSE_TEASER_MSG=محتاج مساعدة في شراء كورس «{{course}}»، وفي عرض؟
# MAJED_COURSE_TEASER_LABEL=💬 ساعدني في الشراء
# MAJED_COURSE_CODE_LABEL=كود الخصم
# MAJED_COURSE_CODE=free100            # override the code for this teaser only
#
# From where to read the course name for {{course}} (a CSS selector pointing at the
# course-title element). Set this if {{course}} shows the wrong text on your theme.
# MAJED_COURSE_NAME_SELECTOR=h1.course-title
#
# Which pages count as a SINGLE course page (comma-separated URL substrings).
# Use a trailing slash so the general shop listing (/shop) is excluded and only an
# individual course page (/shop/<course>) matches. Default: /shop/,/course/
# MAJED_COURSE_SHOWON=/shop/,/course/
# Or match by a CSS selector that exists ONLY on the single product/course page (robust
# if URLs vary). Avoid .oe_website_sale here — it also exists on the /shop listing.
# Default: #product_details, #product_detail, .js_main_product
# MAJED_COURSE_SHOWON_SELECTOR=#product_details, #product_detail, .js_main_product
#
# Catalog teaser (shown on the general /shop listing — the «help me choose a course»
# message). It is auto-hidden on a single course page (where the course teaser shows
# instead) via excludeOnSelector.
# MAJED_SHOP_TEASER_HTML=تحب أساعدك تختار الدورة المناسبة ليك؟ 🎯<br/>وفيه <b>خصم</b> على الدورات 👇
# MAJED_SHOP_TEASER_MSG=تحب تساعدني أختار الدورة المناسبة ليا من دوراتكم؟ وسمعت إن فيه خصم على الدورات.
# MAJED_SHOP_TEASER_LABEL=🎯 ساعدني أختار
# MAJED_SHOP_CODE_LABEL=كود الخصم
# MAJED_SHOP_CODE=engo20               # override the code for this teaser only
# MAJED_SHOP_SHOWON=/shop,/course      # listing URLs (no trailing slash → matches listing + single)
# MAJED_SHOP_EXCLUDE_SELECTOR=#product_details, #product_detail, .js_main_product
#
# Advanced: full control of ALL teasers as a JSON array (overrides the granular vars above).
# MAJED_TEASERS_JSON=[{"showOn":"/shop","html":"...","botMessage":"...","botMessageLabel":"...","code":"free100","codeLabel":"كود الخصم"}]
