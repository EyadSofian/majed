# ── Chatwoot (Application API) ──
CHATWOOT_BASE_URL=https://chat.engosoft.com
CHATWOOT_ACCOUNT_ID=your_account_id
CHATWOOT_API_TOKEN=your_chatwoot_api_token

# API Channel inbox — give EITHER the identifier (preferred) or the numeric id.
# Identifier: from the API channel after creation. Numeric id: from the inbox settings URL.
CHATWOOT_INBOX_IDENTIFIER=your_inbox_identifier
# CHATWOOT_INBOX_ID=

# ── Botpress (bot brain) ──
BOTPRESS_WEBHOOK_URL=https://webhook.botpress.cloud/your-webhook-id
BOTPRESS_PAT=

# ── Widget ──
# The Odoo site origin that hosts the «نور» widget (for CORS). Use exact origin, not a path.
WIDGET_ORIGIN=https://demo.engosoft.com

PORT=3000

# ── «نور» welcome (sent once when the chat opens) ──
WELCOME_ENABLED=true
WELCOME_TEXT=أهلاً 👋 أنا ماجد، مستشارك التعليمي في Engosoft. اسألني عن دوراتك وتقدّمك، أو اختر وسيلة تواصل 👇
WELCOME_CARD_TITLE=تواصل مع Engosoft
WA_NUMBER=966920016295
SUPPORT_EMAIL=aibot@engosoft.com
