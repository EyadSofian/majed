<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Path B — Custom «نور» widget.

        Injects the Majed widget (served by the bridge on Railway) into ALL website pages.
        The widget itself:
          • shows the floating launcher + chat panel (light/dark)
          • fetches trainee context from /ai_webhook/user_context (logged-in users)
          • talks to the bridge:  /widget/session , /widget/message , SSE /widget/stream

        Set the bridge URL in:
          Settings → Technical → Parameters → System Parameters → ai_webhook.bridge_url
    -->
    <template id="engosoft_majed_widget" inherit_id="website.layout">
        <xpath expr="//body" position="inside">

            <t t-set="icp" t-value="request.env['ir.config_parameter'].sudo()"/>
            <t t-set="bridge_url"     t-value="(icp.get_param('ai_webhook.bridge_url', default='') or '').strip().rstrip('/')"/>
            <t t-set="majed_avatar"   t-value="(icp.get_param('ai_webhook.majed_avatar_url', default='/ai_user_context_webhook/static/src/img/majed-avatar.png') or '').strip()"/>
            <t t-set="majed_greeting" t-value="(icp.get_param('ai_webhook.majed_greeting', default='أهلاً، أنا ماجد') or '').strip()"/>
            <t t-set="majed_wa"       t-value="(icp.get_param('ai_webhook.wa_number', default='966920016295') or '').strip()"/>
            <t t-set="majed_email"    t-value="(icp.get_param('ai_webhook.support_email', default='aibot@engosoft.com') or '').strip()"/>
            <t t-set="majed_theme"    t-value="(icp.get_param('ai_webhook.theme', default='light') or '').strip()"/>

            <!-- Config carried via data-* attributes (QWeb escapes these safely, even Arabic). -->
            <t t-if="bridge_url">
                <div id="mjd-config" style="display:none"
                     t-att-data-bridge="bridge_url"
                     t-att-data-avatar="majed_avatar"
                     t-att-data-greeting="majed_greeting"
                     t-att-data-wa="majed_wa"
                     t-att-data-email="majed_email"
                     t-att-data-theme="majed_theme"/>
                <script type="text/javascript">
                    (function(){
                        var c = document.getElementById('mjd-config');
                        if (!c || !c.dataset.bridge) { return; }
                        window.MajedConfig = {
                            bridgeUrl:      c.dataset.bridge,
                            userContextUrl: '/ai_webhook/user_context',
                            avatarUrl:      c.dataset.avatar,
                            greeting:       c.dataset.greeting,
                            waNumber:       c.dataset.wa,
                            supportEmail:   c.dataset.email,
                            theme:          c.dataset.theme || 'light',
                            position:       'right'
                        };
                        var g = document.createElement('script');
                        g.src = c.dataset.bridge.replace(/\/$/, '') + '/majed-widget.js';
                        g.async = true;
                        document.head.appendChild(g);
                    })();
                </script>
            </t>

        </xpath>
    </template>
</odoo>
