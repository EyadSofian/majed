<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Path B — Custom «نور» widget.

        Injects the Majed widget (served by the bridge on Railway) into ALL website pages.
        The widget itself:
          • shows the floating launcher + chat panel (light/dark)
          • fetches trainee context from /ai_webhook/user_context (logged-in users)
          • talks to the bridge:  /widget/session , /widget/message , SSE /widget/stream

        Set the bridge URL in:
          Settings → Technical → Parameters → System Parameters → ai_webhook.bridge_url
    -->
    <template id="engosoft_majed_widget" inherit_id="website.layout">
        <xpath expr="//body" position="inside">

            <t t-set="icp" t-value="request.env['ir.config_parameter'].sudo()"/>
            <t t-set="bridge_url"     t-value="(icp.get_param('ai_webhook.bridge_url', default='') or '').strip().rstrip('/')"/>
            <!--
                الأفاتار: المصدر القانوني الوحيد هو نسخة البريدج (Railway) لأنها بتتحدّث مع كل deploy
                وبيضيف لها الويدجت content-hash للكاش. القيمة الفاضية أو مسار Odoo القديم بيتحوّلوا
                تلقائيًا لرابط البريدج — ومسار Odoo المحلي فاضل fallback لو البريدج وقع.
                عايز صورة مخصصة من CDN خارجي؟ حط رابطها الكامل في ai_webhook.majed_avatar_url.
            -->
            <t t-set="majed_avatar"   t-value="(icp.get_param('ai_webhook.majed_avatar_url', default='') or '').strip()"/>
            <t t-set="majed_avatar"   t-value="majed_avatar if majed_avatar and majed_avatar != '/ai_user_context_webhook/static/src/img/majed-avatar.png' else (bridge_url + '/majed-avatar.png')"/>
            <t t-set="majed_greeting" t-value="(icp.get_param('ai_webhook.majed_greeting', default='أهلاً، أنا ماجد') or '').strip()"/>
            <t t-set="majed_wa"       t-value="(icp.get_param('ai_webhook.wa_number', default='966920016295') or '').strip()"/>
            <t t-set="majed_email"    t-value="(icp.get_param('ai_webhook.support_email', default='aibot@engosoft.com') or '').strip()"/>
            <t t-set="majed_theme"    t-value="(icp.get_param('ai_webhook.theme', default='light') or '').strip()"/>
            <!-- نسخة الويدجت: بتتحدّث مع كل upgrade للموديول → المتصفح يجيب أحدث majed-widget.js فورًا -->
            <t t-set="majed_ver"      t-value="(icp.get_param('ai_webhook.widget_version', default='') or '').strip() or '17.0.4.1.0'"/>
            <!--
                تيزرات مخصّصة (اختياري): حط JSON array في System Parameter باسم ai_webhook.teasers_json
                مثال (تيزر يظهر على صفحات المتجر فقط + زرار يبعت للبوت + كود عرض):
                [{"showOn":"/shop","html":"محتاج مساعدة في الشراء؟","botMessage":"محتاج مساعدة في الشراء","botMessageLabel":"💬 ساعدني","code":"free100","codeLabel":"كود الخصم"}]
                سيبها فاضية لاستخدام التيزرات الافتراضية المدمجة في الويدجت.
            -->
            <t t-set="majed_teasers"  t-value="(icp.get_param('ai_webhook.teasers_json', default='') or '').strip()"/>

            <!-- Config carried via data-* attributes (QWeb escapes these safely, even Arabic). -->
            <t t-if="bridge_url">
                <div id="mjd-config" style="display:none"
                     t-att-data-bridge="bridge_url"
                     t-att-data-avatar="majed_avatar"
                     t-att-data-greeting="majed_greeting"
                     t-att-data-wa="majed_wa"
                     t-att-data-email="majed_email"
                     t-att-data-theme="majed_theme"
                     t-att-data-ver="majed_ver"
                     t-att-data-teasers="majed_teasers"/>
                <script type="text/javascript">
                    (function(){
                        var c = document.getElementById('mjd-config');
                        if (!c || !c.dataset.bridge) { return; }
                        window.MajedConfig = {
                            bridgeUrl:      c.dataset.bridge,
                            userContextUrl: '/ai_webhook/user_context',
                            avatarUrl:      c.dataset.avatar,
                            greeting:       c.dataset.greeting,
                            waNumber:       c.dataset.wa,
                            supportEmail:   c.dataset.email,
                            theme:          c.dataset.theme || 'light',
                            position:       'right'
                        };
                        // تيزرات مخصّصة من System Parameter (اختياري) — لو JSON غلط نتجاهلها ونستخدم الافتراضي
                        if (c.dataset.teasers) {
                            try {
                                var tz = JSON.parse(c.dataset.teasers);
                                if (Array.isArray(tz) &amp;&amp; tz.length) { window.MajedConfig.teasers = tz; }
                            } catch (e) { /* JSON غير صالح — تجاهُل */ }
                        }
                        var g = document.createElement('script');
                        // version query = cache-busting: كل upgrade للموديول يجبر تحميل نسخة جديدة
                        g.src = c.dataset.bridge.replace(/\/$/, '') + '/majed-widget.js?v=' + encodeURIComponent(c.dataset.ver || '0');
                        g.async = true;
                        document.head.appendChild(g);
                    })();
                </script>
            </t>

        </xpath>
    </template>
</odoo>
